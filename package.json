{
  "name": "realgorilla-browser",
  "version": "1.0.0",
  "description": "RealGorilla Browser - The Gorilla Tag themed web browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.realgorilla.browser",
    "productName": "RealGorillaBrowser",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "signtoolOptions": {
        "sign": false
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "node_modules/**/*",
      "package.json"
    ],
    "forceCodeSigning": false
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.15.2"
  }
}